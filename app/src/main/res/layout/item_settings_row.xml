<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="90dp"
    android:background="@color/spotify_black"
    android:padding="16dp">

    <TextView
        android:id="@+id/setting_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_alignParentStart="true"
        android:layout_centerVertical="true"
        android:layout_toStartOf="@+id/setting_switch"
        android:fontFamily="sans-serif-medium"
        android:text="Data Saver"
        android:textColor="@color/white"
        android:textSize="16sp" />

    <TextView
        android:id="@+id/setting_description"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_below="@id/setting_title"
        android:layout_alignParentStart="true"
        android:layout_marginTop="4dp"
        android:layout_toStartOf="@+id/setting_switch"
        android:fontFamily="sans-serif"
        android:text="Sets your audio quality to low and disables artist canvases."
        android:textColor="@color/spotify_light_gray"
        android:textSize="13sp" />

    <Switch
        android:id="@+id/setting_switch"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_alignParentEnd="true"
        android:layout_centerVertical="true"
        android:checked="true"
        android:thumbTint="@color/spotify_green"
        android:trackTint="@color/spotify_dark_gray" />

</RelativeLayout>
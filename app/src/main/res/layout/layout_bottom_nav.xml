<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="72dp"
    android:background="@color/spotify_medium_gray"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:elevation="10dp"
    android:layout_gravity="bottom">

    <LinearLayout
        android:id="@+id/navHome"
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:clickable="true"
        android:focusable="true"
        android:gravity="center"
        android:orientation="vertical">
        <ImageView
            android:id="@+id/ivNavHome"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:contentDescription="@string/nav_home"
            android:src="@drawable/ic_home"
            app:tint="@color/white" />
        <TextView
            android:id="@+id/tvNavHome"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:fontFamily="sans-serif-medium"
            android:text="@string/nav_home"
            android:textColor="@color/white"
            android:textSize="11sp" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/navSearch"
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:clickable="true"
        android:focusable="true"
        android:gravity="center"
        android:orientation="vertical">
        <ImageView
            android:id="@+id/ivNavSearch"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:contentDescription="@string/nav_search"
            android:src="@drawable/ic_search"
            app:tint="@color/spotify_light_gray" />
        <TextView
            android:id="@+id/tvNavSearch"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:fontFamily="sans-serif-medium"
            android:text="@string/nav_search"
            android:textColor="@color/spotify_light_gray"
            android:textSize="11sp" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/navLibrary"
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:clickable="true"
        android:focusable="true"
        android:gravity="center"
        android:orientation="vertical">
        <ImageView
            android:id="@+id/ivNavLibrary"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:contentDescription="@string/nav_library"
            android:src="@drawable/ic_library"
            app:tint="@color/spotify_light_gray" />
        <TextView
            android:id="@+id/tvNavLibrary"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:fontFamily="sans-serif-medium"
            android:text="@string/nav_library"
            android:textColor="@color/spotify_light_gray"
            android:textSize="11sp" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/navSettings"
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:clickable="true"
        android:focusable="true"
        android:gravity="center"
        android:orientation="vertical">
        <ImageView
            android:id="@+id/ivNavSettings"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:contentDescription="@string/settings"
            android:src="@android:drawable/ic_menu_manage"
            app:tint="@color/spotify_light_gray" />
        <TextView
            android:id="@+id/tvNavSettings"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:fontFamily="sans-serif-medium"
            android:text="@string/settings"
            android:textColor="@color/spotify_light_gray"
            android:textSize="11sp" />
    </LinearLayout>

</LinearLayout>
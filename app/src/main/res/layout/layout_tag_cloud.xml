<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@color/spotify_black"
    android:padding="16dp">

    <androidx.constraintlayout.helper.widget.Flow
        android:id="@+id/flow_tags"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        app:constraint_referenced_ids="tag_music,tag_podcasts,tag_live,tag_wrapped,tag_kpop,tag_fitness,tag_focus"
        app:flow_horizontalGap="8dp"
        app:flow_verticalGap="12dp"
        app:flow_wrapMode="aligned"
        app:flow_horizontalStyle="start"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/tag_music"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_pill"
        android:backgroundTint="@color/spotify_green"
        android:fontFamily="sans-serif-medium"
        android:paddingHorizontal="20dp"
        android:paddingVertical="10dp"
        android:text="Music"
        android:textColor="@color/spotify_black"
        android:textSize="14sp" />

    <TextView
        android:id="@+id/tag_podcasts"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_pill"
        android:fontFamily="sans-serif-medium"
        android:paddingHorizontal="20dp"
        android:paddingVertical="10dp"
        android:text="Podcasts"
        android:textColor="@color/white"
        android:textSize="14sp" />

    <TextView
        android:id="@+id/tag_live"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_pill"
        android:fontFamily="sans-serif-medium"
        android:paddingHorizontal="20dp"
        android:paddingVertical="10dp"
        android:text="Live"
        android:textColor="@color/white"
        android:textSize="14sp" />

    <TextView
        android:id="@+id/tag_wrapped"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_pill"
        android:fontFamily="sans-serif-medium"
        android:paddingHorizontal="20dp"
        android:paddingVertical="10dp"
        android:text="Wrapped"
        android:textColor="@color/white"
        android:textSize="14sp" />

    <TextView
        android:id="@+id/tag_kpop"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_pill"
        android:fontFamily="sans-serif-medium"
        android:paddingHorizontal="20dp"
        android:paddingVertical="10dp"
        android:text="K-Pop"
        android:textColor="@color/white"
        android:textSize="14sp" />

    <TextView
        android:id="@+id/tag_fitness"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_pill"
        android:fontFamily="sans-serif-medium"
        android:paddingHorizontal="20dp"
        android:paddingVertical="10dp"
        android:text="Fitness"
        android:textColor="@color/white"
        android:textSize="14sp" />

    <TextView
        android:id="@+id/tag_focus"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_pill"
        android:fontFamily="sans-serif-medium"
        android:paddingHorizontal="20dp"
        android:paddingVertical="10dp"
        android:text="Focus"
        android:textColor="@color/white"
        android:textSize="14sp" />

</androidx.constraintlayout.widget.ConstraintLayout>